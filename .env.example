# Required
CRUSTYCLAW_TELEGRAM_TOKEN=your_bot_token_here
CRUSTYCLAW_ADMIN_CHAT_ID=123456789

# Optional: additional allowed chat IDs (comma-separated)
# CRUSTYCLAW_ALLOWED_CHAT_IDS=111,222,333

# Claude CLI
# CRUSTYCLAW_MODEL=sonnet
# CRUSTYCLAW_FALLBACK_MODEL=haiku
# CRUSTYCLAW_MAX_BUDGET=10.0
# CRUSTYCLAW_WORKING_DIR=/workspace
# CRUSTYCLAW_PERMISSION_MODE=dangerously_skip
# CRUSTYCLAW_SYSTEM_PROMPT=You are a helpful assistant.
# CRUSTYCLAW_TIMEOUT=300
# CRUSTYCLAW_RATE_LIMIT_RETRY=30

# Heartbeat
# CRUSTYCLAW_HEARTBEAT_ENABLED=true
# CRUSTYCLAW_HEARTBEAT_INTERVAL=900
# CRUSTYCLAW_HEARTBEAT_PROMPT=Review any pending context...
# CRUSTYCLAW_HEARTBEAT_NOTIFY=true

# Voice transcription (requires whisper-cpp binary and model)
# CRUSTYCLAW_VOICE_ENABLED=true
# CRUSTYCLAW_WHISPER_MODEL=/path/to/ggml-base.en.bin

# Logging
RUST_LOG=info

# Docker deployment
# Run `crustyclaw setup` on the host first to authenticate with Claude and configure
# Telegram. docker-compose.yml mounts ~/.claude (OAuth tokens) and ~/.crustyclaw
# (config + data) from the host into the container.
