{
  "hooks": {
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "CC_BIN=\"${HOME}/.crustyclaw/bin/crustyclaw\"; [ -x \"$CC_BIN\" ] && \"$CC_BIN\" stop 2>/dev/null; true",
            "timeout": 5000
          }
        ]
      }
    ]
  }
}
